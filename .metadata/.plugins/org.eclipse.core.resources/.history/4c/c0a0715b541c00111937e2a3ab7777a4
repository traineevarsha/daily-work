	static boolean oddoreven(int num) {
		return num % 2 == 0;
	}

	static void stars(int n) {
		for(int i=n;i>=1;i--) {
			for (int j=1; j<=i; j++) {
				System.out.print("*");
			}
			System.out.println();
		}
		}
	static void largestnum(int a,int b,int c) {
		if(a>b && b>c) {
			System.out.println("largest num:" +a);
		}
			else if(b>a && b>c) {
				System.out.println("largest" +b);
			}
			else {
				System.out.println("largest" +c);
		
			}
		}
	}
	
		
	

	
	

